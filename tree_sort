'''
    Данная программа реализует сортировку бинарным деревом
    В основе лежит структура "бинарное дерево" - существует узел(предок), имеющий
определённое значение, от которого отходят две "ветки", соединяющие его с такими же
узлами(потомками). Каждый элемент связан со своими предками и потомками определёнными
законами: больше/меньше.
    Относится к классу быстрых сортировок сложности О(n*log(n)), однако может деградировать
до О(n^2)

Авторы: Жилин Владимир, Щавинская Ульяна, Глухих Антон, Гривцова Кристина, Пустовойт Максим
'''
#необходимо для тестирования программы
from random import randint

#создаем новый класс для структуры "бинарное дерево"
class Node:
    
    def __init__(tree, data):
        
        tree.left = None #создаем левую ветку
        tree.right = None #создаем правую ветку
        tree.inf = data #создаем узел

    #функция для заполнения узла дерева
    def fillnode(tree, data):
        
        if tree.inf: #проверяем значение в узле, выполняем, если оно не равно None
            
            if data < tree.inf: #если элемент меньше значения узла, проходим по левой ветке
                
                if tree.left is None: #заполняем левый потомок узла, если тот пуст
                    
                    tree.left = Node(data)
                    
                else: #снова выполняем функцию, если тот полон
                    
                    tree.left.fillnode(data)
                    
            else: #если элемент больше значения в узле, идентично предыдущей ситуации проходим по правой ветке
                
                if tree.right is None:
                    
                    tree.right = Node(data)
                    
                else:
                    
                    tree.right.fillnode(data)
                    
        else: #если значение в узле отсутствует (равно None)
            
            tree.inf = data

    #функция переноса элементов из массива в дерево
    def filltree(tree, a):
        
        for i in a:
            
            tree.fillnode(i)

    #функция перезаписи значений из дерева в массив
    def writetree(tree,a):
        
        if tree.left: #проверяем значение в левом узле
            
            tree.left.writetree(a) #переходим к левому крайнему(самому малому) значению через рекурсию
            
        a.append(tree.inf) #считываем его
        
        if tree.right: #проверяем значение в левом узле
            
            tree.right.writetree(a) #переходим к правому узлу

#функция, объединяющая все предыдущие для удобства пользователя
def treesort(a):
    
    tree = Node(None) #создаем элемент класса "бинарное дерево"
    a1 = []
    tree.filltree(a)
    tree.writetree(a1) 
    a1
    
    return a1 #возвращаем отсортированный массив

#далее идёт блок проверки программы

#функция, создающий случайный массив с элементами типа int (с ними проще работать), принимающими значения от 1 до 10000, длинной n
def createarr(n):
    
    a = []
    for i in range(n):
        
        a.append(randint(1,10000)) #вводится случайное значение
        
    return a

#создается массив, выводится он и отсортированный вариант
a = createarr(10)
print(a)
print(treesort(a))
